# Anthropic API key used by the Cloudflare Worker (src/index.js) to classify
# grocery items that the local keyword table doesn't recognize.
#
# This file is a reference only — the Worker does not read .env directly.
#
# Local development (`npm run dev` / `wrangler dev`):
#   Copy this file to `.dev.vars` (already gitignored) and fill in a real key:
#     cp .env.example .dev.vars
#
# Production:
#   Never put the key in a file. Set it as a Worker secret instead:
#     npx wrangler secret put ANTHROPIC_API_KEY

ANTHROPIC_API_KEY=your-anthropic-api-key-here
